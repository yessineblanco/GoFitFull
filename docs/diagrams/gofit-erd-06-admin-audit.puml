@startuml GoFit_ERD_06_Admin
title ERD — Admin settings, notifications log, audit (public)

hide circle
skinparam linetype ortho

class "auth.users" as u <<auth>> {
  id : uuid PK
}

class "admin_settings" as aset <<Table>> {
  id / key
  value JSONB
}

class "admin_notifications" as an <<Table>> {
  id : uuid PK
  admin_user_id : uuid FK -> u
}

class "admin_audit_log" as al1 <<Table>> {
  id : uuid PK
  admin_user_id : uuid FK -> u
}

class "admin_audit_logs" as al2 <<Table>> {
  id : uuid PK
  admin_user_id : uuid FK -> u
}

u ||--o{ al1
u ||--o{ al2
u ||--o{ an

note bottom of al1
  add_admin_role.sql — singular name
end note

note bottom of al2
  create_admin_audit_logs.sql — plural name
  Two similar tables from different migrations;
  consolidate in app / DB if possible.
end note

note bottom of aset
  database/migrations/create_admin_settings.sql
end note

note bottom of an
  database/migrations/create_admin_notifications.sql
end note

@enduml
