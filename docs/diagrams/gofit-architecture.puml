@startuml GoFit_Architecture
!pragma layout smetana
title GoFit - Component / deployment view

package "Client devices" {
  [GoFit mobile app\nExpo, React Native, Zustand] as Mobile
}

package "Web" {
  [Admin panel\nNext.js, Supabase SSR] as Admin
}

package "Realtime video" {
  [LiveKit] as LK
}

package "Supabase" {
  [Auth] as Auth
  database "PostgreSQL\n+ RLS" as PG
  [Storage] as Stor
  [Realtime] as Realtime
}

package "Other" {
  [Cloudflare R2\nS3-compatible admin uploads] as R2
  [Android Health Connect\nwearables v1] as Health
}

Mobile --> Auth : JWT / session
Mobile --> PG : supabase-js
Mobile --> Stor
Mobile --> Realtime
Mobile --> LK
Mobile ..> Health : optional

Admin --> Auth
Admin --> PG
Admin --> R2

note bottom of PG
  Inferred from database/migrations
  and @supabase/supabase-js usage.
end note

@enduml
