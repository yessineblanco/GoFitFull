# EAS Build archive exclusions
# Location: EAS project root (next to eas.json), i.e. GoFitMobile/.easignore

# Sibling projects and large folders (monorepo, if EAS uploads from repo root)
admin-panel/
database/
docs/
Storage/

# Native build artifacts (regenerated by Expo prebuild in the cloud)
/android/
/ios/
.expo/
dist/
web-build/

# Large media files
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Version control
.git/

# Documentation (not needed for build)
*.md

# Environment and secrets
.env
.env*.local