@startuml GoFit_Sequence_WorkoutSession
!pragma layout smetana
title GoFit - Sequence: start, pause/save, resume, complete workout session

actor User
participant "GoFit App\n(Expo / RN)" as App
participant "workoutService" as Svc
participant "Supabase JS" as SB
database "Postgres (RLS)" as DB

User -> App: Start workout from library / plan
App -> Svc: createWorkoutSession(userId, workout)
Svc -> SB: complete previous incomplete session if present
SB -> DB: UPDATE workout_sessions
Svc -> SB: INSERT workout_sessions
SB -> DB: INSERT
DB --> App: new session_id

loop Exercises and sets
  User -> App: Complete sets, rest, weights
  note right of App
    Timers and current set state are local.
    Session progress is serialized to exercises_completed.
  end note
end

alt User pauses or leaves before finishing
  User -> App: Pause / leave session
  App -> Svc: updateWorkoutSession(id, exercises_completed)
  Svc -> SB: UPDATE workout_sessions
  SB -> DB: UPDATE
  App -> User: Return to root tab / show resume entry
else User resumes incomplete session
  User -> App: Tap resume
  App -> Svc: getLatestIncompleteWorkoutSession(userId)
  Svc -> SB: SELECT workout_sessions where completed_at is null
  SB -> DB: SELECT
  DB --> App: saved exercises_completed
end

User -> App: Tap finish
App -> Svc: updateWorkoutSession(id, completed_at,\nduration, exercises_completed)
Svc -> SB: UPDATE workout_sessions
SB -> DB: UPDATE
DB --> App: saved session
App -> User: Workout summary screen

@enduml
